# ════════════════════════════════════════════════════════════════════════
# admin-mydelivery-api — variáveis de ambiente (TEMPLATE PÚBLICO)
# ════════════════════════════════════════════════════════════════════════
# ⚠️  ESTE ARQUIVO É COMMITADO. NUNCA COLOQUE CREDENCIAIS REAIS AQUI.
# Copie pra .env (gitignored) ou configure direto no painel do Railway.

# ── Servidor ──
PORT=8090

# ── Banco ADMIN (escrita) ──
DB_URL_ADMIN=jdbc:mysql://localhost:3306/admin_mydelivery?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=America/Sao_Paulo&allowPublicKeyRetrieval=true
DB_USERNAME_ADMIN=root
DB_PASSWORD_ADMIN=REPLACE_WITH_YOUR_MYSQL_PASSWORD

# ── Banco MAIN MyDelivery (LEITURA only) ──
DB_URL_MAIN=jdbc:mysql://localhost:3306/mydelivery_db?useSSL=false&serverTimezone=America/Sao_Paulo&allowPublicKeyRetrieval=true
DB_USERNAME_MAIN=root
DB_PASSWORD_MAIN=REPLACE_WITH_YOUR_MYSQL_PASSWORD

# ── JWT do admin (gere com: openssl rand -base64 64) ──
ADMIN_JWT_SECRET=REPLACE_WITH_BASE64_RANDOM_64_BYTES
ADMIN_JWT_EXPIRATION=28800000

# ── CORS ──
ADMIN_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Cloudinary (compartilhado com o main) ──
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET
